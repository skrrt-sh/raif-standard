# Supply-chain hardening for the npm CLI path (publish workflow + any consumer
# that installs `raif` with npm instead of bun).

# Kill the preinstall/postinstall execution vector used by recent npm worms.
ignore-scripts=true

# Verify sigstore provenance signatures on every installed package.
audit-signatures=true

# Exact-version installs — no implicit semver drift.
save-exact=true

# Refuse to run under a Node/engine that does not satisfy `engines`.
engine-strict=true

registry=https://registry.npmjs.org/
