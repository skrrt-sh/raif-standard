{
  "name": "raif-format",
  "version": "0.5.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "RAIF — a repairable, JSON-alternative wire format for LLM tool-call output.",
  "keywords": [
    "raif",
    "llm",
    "tool-call",
    "json",
    "wire-format",
    "repair",
    "decode",
    "encode"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skrrt-sh/raif-standard.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/skrrt-sh/raif-standard/tree/main/packages/js#readme",
  "bugs": {
    "url": "https://github.com/skrrt-sh/raif-standard/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "check:pack": "publint && attw --pack .",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "bun run build",
    "demo": "bun run bench/demo.ts",
    "bench": "bun run bench/bench.ts",
    "tui": "bun run bench/tui.ts",
    "harness": "bun run bench/harness.ts",
    "dataset": "bun run bench/dataset.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.12",
    "@toon-format/toon": "^2.3.0",
    "@types/bun": "latest",
    "gpt-tokenizer": "^2.5.1",
    "jsonrepair": "^3.14.0",
    "publint": "^0.3.14",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0",
    "yaml": "^2.9.0"
  }
}
